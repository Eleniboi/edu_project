// this function change the last two words to Uppercase leaving the previous lower case
func LastTwoToUpper(words []string, n int) []string {
	if n >= len(words)-1 {
		n = len(words)
	}
	for i := len(words) - n; i < len(words); i++ {
		words[i] = strings.ToUpper(words[i])
	}
	return words
}

func main() {
	words := []string{"small", "rat", "what", "is", "wrong"}
	fmt.Println(LastTwoToUpper(words, 2))
}



