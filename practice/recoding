func fixQuotes(text string) string {
	text = strings.Trim(text, " '")
	return "'" + text + "'"
}

func main() {
	sam := " ' God is Good ' "
	omafu := "  ' You are great '  "

	sam = fixQuotes(sam)
	omafu = fixQuotes(omafu)

	fmt.Printf("%q\n", sam)
	fmt.Printf("%q\n", omafu)

}
