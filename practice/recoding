package main 


import (
	"fmt"
	"unicode"
)
// "Gooo" -> "letter"
// "727" -> "digit"
// "!?," -> "punctuation"

func CheckPrint(s string) string{
	for _, r := range s {
		if unicode.IsDigit(r){
			return "digit"
		}else if unicode.IsLetter(r){
			return "letter"
		}else if unicode.IsPunct(r){
			return "punctuation"
		}
	}
	return "invalid"
}

func main() {
	fmt.Println(CheckPrint("Gooo"))
	fmt.Println(CheckPrint("727"))
	fmt.Println(CheckPrint("!,?"))
}

