package main 

import (
	"fmt"
	"strings"
)

func fixPunct(s []string)string{
	result := ""
	for i, word := range s {
	if i > 0 && !strings.ContainsAny(word, "?.,:;!"){
		result += " "
	}
	result += word
	}
	return result
}

func main() {
	fmt.Println(fixPunct([]string{"hello",",","world","!"}))
}

