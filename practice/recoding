)
func command(word []string, n int) []string{

	for i := 0; i < len(word); i++{
		if word[i]== "(up,2)" || word[i] == "(up, 2)"{

			for j := i-1; j >= i-n && j >= 0; j--{
			word[j] = strings.ToUpper(word[j])
		}
			word = append(word[:i], word[i+1:]...)
		i--
	}
	}
	return word 
}

func fixPunct(s string)string{

	result := strings.Fields(s)
	Nword := ""
	for i, word := range result{
		if i > 0 && !strings.ContainsAny(word, ",.:;?!"){
			Nword += " "
		}
		Nword += word
	}
	return Nword

}

func fixArticle(s string)string{
	//s = strings.Replace(s, "a", "an", 1)
	result := strings.Fields(s)

	for i := range result{
		if result[i] == "a" && strings.Contains("aeiouhAEIOUH", string(result[i+1][0])){
			result[i] = "an"
		}else if result[i] == "an" && !strings.Contains("aeiouhAEIOUH", string(result[i+1][0])){
			result[i] = "a"
		}
	}
	return strings.Join(result, " ")
}


func main() {
	fmt.Println(command([]string{"my","brother","is","a", "great", "guy","(up,2)","you","too","sabi","(up, 2)","boy"}, 2))
	fmt.Println(fixPunct("what ? wow !"))
	fmt.Println(fixArticle("i ate a apple with a orange, an book"))
}
