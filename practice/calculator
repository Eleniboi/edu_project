package main

import "fmt"

func add(a int, b int) int {
	return a + b
}
func substract(a int, b int) int {
	return a - b
}

func main() {
	var op string
	for {
		fmt.Print("choose operation: add , substract , divide.")
		_, err := fmt.Scanln(&op)

		if err != nil {
			fmt.Println("invalid input")
			return
		}

		if op == "exit" || op == "Exit" {
			fmt.Println("Goodbye")
			return
		} else if op == "add" || op == "Add" {

			var num1, num2 int
			fmt.Print("Enter first number: ")
			fmt.Scanln(&num1)

			fmt.Print("Enter second number: ")
			fmt.Scanln(&num2)

			result := add(num1, num2)
			fmt.Println("Result:", result)

		} else if op == "substract" || op == "Substract" {

			var num1, num2 int
			fmt.Print("Enter first number: ")
			fmt.Scanln(&num1)
			fmt.Print("Enter second number: ")
			fmt.Scanln(&num2)

			result := substract(num1, num2)
			fmt.Println("Result: ", result)
		}
	}
}
