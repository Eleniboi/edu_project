package main

import (
	"fmt"
	"strings"
)

func FandL(s string) string {

	s = strings.ToLower(s)
	s = strings.ToUpper(s[:1]) + s[1:]
	s = s[:len(s)-1] + strings.ToUpper(string(s[len(s)-1]))
	return s
}

func main() {
	fmt.Println(FandL("heLLo"))
}

//THIS FUNCTION CAPITALIZE THE FIRST AND LAST WORD IN A SLICE OF STRING
package main 

import (
	"fmt"
	"strings"
)

func UpperN(s []string)[]string{
	if len(s)== 0 {
		return s
	}

	result := make([]string, len(s))

	for i, word := range s {
		if i == 0 || i == len(s)-1{
			result[i] = strings.ToUpper(word)
		}else{
			result[i] = strings.ToLower(word)
		}
	}
	return result
}

func main() {
	fmt.Println(UpperN([]string{"hi","HOW","ARE","you"}))
}

//THIS FUNCTION CAPITALIZE ONLY THE ON EVEN INDEX AND LEAVE THE REST LOWER CASE 

package main

import (
	"fmt"
	"strings"
)

func CapFirst(s string)string{
	for i := 0; i < len(s); i++{
		if i % 2 == 0{
			fmt.Print(strings.ToUpper(string(s[i])))
		}else if i %  2 != 0{
			fmt.Print(strings.ToLower(string(s[i])))
		}
	}
	return ""
}

func main() {
	fmt.Println(CapFirst("hELLo"))
}

