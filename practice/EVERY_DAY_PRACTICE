THIS FUNCTION REVERSE AND PRINT THE REVERSED VERSION OF THE STRING e.g samuel😊 -> 😊leumas
package main 

import (
	"fmt"
)

func Reverse(s string) string{

	runes := []rune(s)

	for i, j := 0, len(runes)-1; i < j; i, j = i+1, j-1{
		runes[i], runes[j] = runes[j], runes[i]
	}

	return string(runes)
}

func main() { 
	fmt.Println(Reverse("samuel😊"))
	fmt.Println(Reverse("madam"))
	fmt.Println(Reverse("bobo"))
}

THIS FUNCTION CHECKS IF A STRING IS A PALINDROME AND RETURN TRUE ELSE RETURN FALSE

package main 

import (
	"fmt"
	"strings"
)

func IsPalindrome(s string)bool {
	if s == "" { // this line handle empty string
		return false
	}

	s = strings.ToLower(s) // this turn the whole string to lower case 

	runes := []rune(s)

	for i, j := 0, len(runes)-1; i < j; i,j = i+1, j-1{
		if runes[i] == runes[j]{
			return true
		}
	}
	return false
}

func main() {
	fmt.Println(IsPalindrome("Madam"))
	fmt.Println(IsPalindrome("adam"))
	fmt.Println(IsPalindrome(""))


}

