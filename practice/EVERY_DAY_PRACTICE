package main 

import (
	"fmt"
	"strings"
)

func fixArticle(s string)string{

	result := strings.Fields(s)
	for i := range result{
		if result[i] == "a" && strings.Contains("aeiouhAEIOUH", string(result[i+1][0])){
			result[i] = "an"
		}
	}
	return strings.Join(result, " ")
}

func main() {
	fmt.Println(fixArticle("a book  and a orange is a apple"))
}
//THIS FUNCTION UPPERCASE THE PREVIOUS WORD WHEN IT SEES THE COMMAND (up) and if a number is inserted it work according to the number
package main 

import (
	"fmt"
	"strings"
)

func command(words []string, n int) []string {
	for i := 0; i < len(words); i++ {
		if words[i] == fmt.Sprintf("(up,%d)", n) {
			
			for j := 1; j <= n; j++ {
				if i-j >= 0 {
					words[i-j] = strings.ToUpper(words[i-j])
				}
			}
			words = append(words[:i], words[i+1:]...)
			i--
		}
	}
	return words
}
func main(){
	fmt.Println(command([]string{"so","lovable","wow","(up,2)"}, 2))
}

