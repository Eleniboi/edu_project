//This function dectect and return UPPERCASE if the value in command == "up" it returns LOWERCASE if command == "low" and UNKNOWN if the command is not found 

package main

import (
	"fmt"
	"strings"
)

func DetectCommand(s string) string {

	s = strings.TrimSpace(s)

	if strings.HasPrefix(s, "(") && strings.HasSuffix(s, ")") {

		command := s[1 : len(s)-1]

		if command == "up" {
			return "UPPERCASE"
		} else if command == "low" {
			return "LOWERCASE"
		} else {
			return "UNKNOWN"
		}
	}

	return "NOT A COMMAND"
}

func main() {

	fmt.Println(DetectCommand("   (up)   "))
	fmt.Println(DetectCommand("   (low)   "))
	fmt.Println(DetectCommand("   (hex   "))

}

