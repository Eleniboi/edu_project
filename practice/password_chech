	writer := bufio.NewWriter(os.Stdout)

	var name string
	fmt.Println("Enter User Name: ")
	fmt.Scan(&name)
	fmt.Println("Enter password Name: ")

	count := 5

	for {
		scanner.Scan()
		Password := scanner.Text()

		if Password == "golang123" {
			writer.WriteString("you are welcome the password correct")
			writer.Flush()
			break
		} else {
			fmt.Println("Access Denied!!! Try again")
			fmt.Println("you have, ",count,"more trials")
		}
		if count == 0 {
			fmt.Println(name, "You Are Not the real USER 😂😝")
			break
		}
		count--
	}

}
